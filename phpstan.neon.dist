includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    symfony:
        container_xml_path: var/cache/test/App_KernelTestDebugContainer.xml
    scanDirectories:
        - var/cache/test/Symfony/Config
