includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-symfony/extension.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    symfony:
        # phpstan-symfony 2.x renamed container_xml_path → containerXmlPath
        # (camelCase). Keeping the old key silently disables the check.
        containerXmlPath: var/cache/test/App_KernelTestDebugContainer.xml
    scanDirectories:
        - var/cache/test/Symfony/Config
