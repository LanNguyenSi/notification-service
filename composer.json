{
    "name": "pandora/notification-service",
    "description": "Notification service for email, SMS and push delivery.",
    "type": "project",
    "license": "MIT",
    "keywords": ["notification", "email", "sms", "push", "symfony"],
    "require": {
        "php": "^8.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "psr/log": "^3.0",
        "symfony/console": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/runtime": "^6.4",
        "symfony/yaml": "^6.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-phpunit": "^1.4",
        "phpstan/phpstan-symfony": "^1.4",
        "phpunit/phpunit": "^10.5",
        "symfony/browser-kit": "^6.4",
        "symfony/css-selector": "^6.4",
        "symfony/dom-crawler": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "phpstan": "phpstan analyse",
        "check": [
            "@test",
            "@phpstan"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
